/*
 * frdm_mcxn947.overlay
 * Configuración de hardware para el proyecto frdm_env_monitor
 * Board: NXP FRDM-MCXN947
 */

/ {
    chosen {
        zephyr,console    = &lpuart4;
        zephyr,shell-uart = &lpuart4;
    };

    /*
     * Aliases para que el código C acceda a los periféricos
     * con nombres independientes del hardware concreto.
     */
    aliases {
        led-red   = &rgb_red;
        led-green = &rgb_green;
        led-blue  = &rgb_blue;
        accel     = &lis3dh;
        env-sensor= &bme680;
        ref-temp  = &p3t1755;
        touch-adc = &adc0;
    };

    /* ── RGB LED ─────────────────────────────────────────────────────────── */
    leds {
        compatible = "gpio-leds";

        rgb_red: led_red {
            gpios = <&gpio0 10 GPIO_ACTIVE_LOW>;
            label = "RGB Red";
        };
        rgb_green: led_green {
            gpios = <&gpio0 11 GPIO_ACTIVE_LOW>;
            label = "RGB Green";
        };
        rgb_blue: led_blue {
            gpios = <&gpio0 12 GPIO_ACTIVE_LOW>;
            label = "RGB Blue";
        };
    };
};

/* ── I2C3 — BME680 ────────────────────────────────────────────────────────── */
&lpi2c3 {
    status = "okay";
    clock-frequency = <I2C_BITRATE_FAST>;   /* 400 kHz */

    bme680: bme680@76 {
        compatible = "bosch,bme680";
        reg = <0x76>;                        /* SDO = GND → 0x76 */
        label = "BME680";
    };
};

/* ── Pinmux para Flexcomm2 como I2C (P4_0 = SDA, P4_1 = SCL) ────────────
 *
 * El MCXN947 tiene un sistema de pinmux: cada pin físico puede cumplir
 * varias funciones (GPIO, I2C, SPI, UART...). Aquí le decimos que P4_0
 * y P4_1 deben actuar como SDA/SCL del Flexcomm2.
 *
 * bias-pull-up      → resistencias pull-up internas (necesarias en I2C)
 * drive-open-drain  → I2C requiere salida open-drain por protocolo
 * input-enable      → el pin también recibe datos (bidireccional)
 * slew-rate = fast  → transiciones rápidas para 400 kHz
 */
&pinctrl {
    pinmux_flexcomm2_lpi2c: pinmux_flexcomm2_lpi2c {
        group0 {
            pinmux = <FC2_P0_PIO4_0>,   /* SDA → P4_0 */
                     <FC2_P1_PIO4_1>;   /* SCL → P4_1 */
            slew-rate = "fast";
            drive-strength = "low";
            input-enable;
            bias-pull-up;
            drive-open-drain;
        };
    };
};

/* ── I2C2 (Flexcomm2) — LIS3DH ───────────────────────────────────────────
 *
 * flexcomm2_lpi2c2 es el nombre del nodo I2C en el devicetree base de
 * Zephyr para la FRDM-MCXN947. Cada Flexcomm puede ser I2C, SPI o UART
 * — aquí lo configuramos como I2C.
 *
 * El LIS3DH en modo I2C tiene dirección 0x18 cuando SDO está en GND.
 * CS debe estar en VCC para habilitar el modo I2C (ver conexionado).
 */
&flexcomm2_lpi2c2 {
    status = "okay";
    pinctrl-0 = <&pinmux_flexcomm2_lpi2c>;
    pinctrl-names = "default";
    clock-frequency = <I2C_BITRATE_FAST>;   /* 400 kHz */

    lis3dh: lis3dh@18 {
        compatible = "st,lis3dh";
        reg = <0x18>;                        /* SDO = GND → 0x18 */
        label = "LIS3DH";
    };
};

/* ── I3C0 — P3T1755DP (sensor embebido en la tarjeta) ───────────────────── */
&i3c0 {
    status = "okay";
    /* Dirección I3C dinámica asignada durante DAA */
    p3t1755: p3t1755@08 {
        compatible = "nxp,p3t1755";
        reg = <0x08 0x00 0x00>;
        label = "P3T1755DP";
    };
};

/* ── ADC0 — Touch slider (lectura capacitiva) ────────────────────────────── */
&adc0 {
    status = "okay";
    #io-channel-cells = <1>;
};

/* ── LPUART4 — Consola / reporte de datos ───────────────────────────────── */
&lpuart4 {
    status = "okay";
    current-speed = <115200>;
};
